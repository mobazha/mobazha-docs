{
  "name": "mobazha-docs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && npm run deploy:built",
    "deploy:built": "wrangler deploy --config dist/server/wrangler.json",
    "deploy:preview": "npm run build && npm run deploy:preview:built",
    "deploy:preview:built": "wrangler versions upload --config dist/server/wrangler.json",
    "deploy:dry-run": "npm run build && wrangler deploy --dry-run --config dist/server/wrangler.json",
    "generate:content": "node scripts/generate-doc-registry.mjs && node scripts/generate-publication.mjs",
    "sync:openapi": "node scripts/sync-openapi.mjs",
    "check:openapi": "node scripts/sync-openapi.mjs --check",
    "check:routes": "node scripts/check-routes.mjs",
    "check:external-links": "node scripts/check-external-links.mjs",
    "check:source-contracts": "node scripts/check-source-contracts.mjs",
    "check:source-contracts:strict": "node scripts/check-source-contracts.mjs --require-current",
    "check:freshness": "node scripts/check-freshness.mjs",
    "check:visual-evidence": "node scripts/check-visual-evidence.mjs",
    "test:content": "node --test scripts/content-files.test.mjs",
    "test:experience": "playwright test",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:records": "node scripts/validate-records.mjs",
    "check": "npm run test:content && npm run validate:content && npm run validate:records && npm run check:freshness && npm run check:visual-evidence && npm run check:openapi && npm run lint && npm run build"
  },
  "dependencies": {
    "@scalar/api-reference-react": "^0.9.53",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@cloudflare/vite-plugin": "1.43.0",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.3",
    "wrangler": "4.107.0",
    "yaml": "^2.9.0"
  },
  "type": "module"
}
