{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.mobazha.org/videos.schema.json",
  "title": "Mobazha public video catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reviewed", "videos"],
  "properties": {
    "$schema": { "const": "https://docs.mobazha.org/videos.schema.json" },
    "schema_version": { "const": "1.0" },
    "reviewed": { "type": "string", "format": "date" },
    "videos": {
      "type": "array",
      "items": { "$ref": "#/$defs/video" }
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": {
          "type": "string",
          "pattern": "^https://media\\.mobazha\\.org/"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "imageAsset": {
      "allOf": [
        { "$ref": "#/$defs/asset" },
        { "required": ["width", "height"] }
      ]
    },
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "startSeconds": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "caption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "language", "label", "kind"],
      "properties": {
        "url": { "type": "string", "pattern": "^https://media\\.mobazha\\.org/" },
        "language": { "enum": ["en", "zh-CN"] },
        "label": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["captions", "subtitles"] },
        "default": { "type": "boolean" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "href"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "href": { "type": "string", "pattern": "^/" }
      }
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "title",
        "summary",
        "kind",
        "status",
        "language",
        "primaryPersona",
        "personas",
        "goals",
        "productPromises",
        "durationSeconds",
        "featured",
        "outcome",
        "disclosure",
        "media",
        "recordedAt",
        "reviewed",
        "appliesTo",
        "evidence",
        "primaryAction",
        "relatedDocs",
        "chapters",
        "transcript"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9]{4}$" },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["story", "task", "proof", "release"] },
        "status": { "enum": ["Current", "Beta", "Preview"] },
        "language": { "enum": ["en", "zh-CN"] },
        "primaryPersona": {
          "enum": ["Buyer", "Seller", "Moderator", "Operator", "Promoter", "Developer", "Evaluator"]
        },
        "personas": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["Buyer", "Seller", "Moderator", "Operator", "Promoter", "Developer", "Evaluator"]
          }
        },
        "goals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["Sell", "Buy", "Pay", "Deliver", "Recover", "Grow", "Operate", "Build"]
          }
        },
        "productPromises": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["Own", "Connect", "Trade", "Extend"] }
        },
        "durationSeconds": { "type": "integer", "minimum": 1 },
        "featured": { "type": "boolean" },
        "outcome": { "type": "string", "minLength": 1 },
        "disclosure": { "type": "string", "minLength": 1 },
        "media": {
          "type": "object",
          "additionalProperties": false,
          "required": ["video", "cover", "poster"],
          "properties": {
            "video": { "$ref": "#/$defs/asset" },
            "cover": { "$ref": "#/$defs/imageAsset" },
            "poster": { "$ref": "#/$defs/imageAsset" },
            "captions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/caption" }
            }
          }
        },
        "recordedAt": { "type": "string", "format": "date" },
        "reviewed": { "type": "string", "format": "date" },
        "appliesTo": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "url"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "pattern": "^https://" }
          }
        },
        "primaryAction": { "$ref": "#/$defs/link" },
        "relatedDocs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^/" }
        },
        "chapters": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/chapter" }
        },
        "transcript": { "type": "string", "minLength": 80 }
      }
    }
  }
}
