{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.mobazha.org/visual-evidence.schema.json",
  "title": "Mobazha documentation visual evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "reviewed", "visuals"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "string", "const": "1.2" },
    "reviewed": { "type": "string", "format": "date" },
    "visuals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "src", "sha256", "kind", "width", "height", "alt", "caption", "claim", "transcript", "transcript_zh", "privacy_review", "source", "source_revision", "applies_to", "reviewed"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "src": { "type": "string", "pattern": "^/images/docs/" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "mobile_src": { "type": "string", "pattern": "^/images/docs/" },
          "mobile_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "kind": { "type": "string", "enum": ["product-screenshot", "terminal-output", "conceptual"] },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "mobile_width": { "type": "integer", "minimum": 1 },
          "mobile_height": { "type": "integer", "minimum": 1 },
          "alt": { "type": "string", "minLength": 20 },
          "caption": { "type": "string", "minLength": 10 },
          "claim": { "type": "string", "minLength": 20 },
          "transcript": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 3 } },
          "transcript_zh": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 2 } },
          "privacy_review": { "type": "string", "enum": ["synthetic-only", "redacted", "public-demo-reviewed"] },
          "source": { "type": "string", "format": "uri", "pattern": "^https://" },
          "source_revision": { "type": "string", "minLength": 1 },
          "applies_to": { "type": "string", "minLength": 1 },
          "reviewed": { "type": "string", "format": "date" }
        },
        "dependentRequired": {
          "mobile_src": ["mobile_sha256", "mobile_width", "mobile_height"],
          "mobile_sha256": ["mobile_src", "mobile_width", "mobile_height"],
          "mobile_width": ["mobile_src", "mobile_sha256", "mobile_height"],
          "mobile_height": ["mobile_src", "mobile_sha256", "mobile_width"]
        }
      }
    }
  }
}
